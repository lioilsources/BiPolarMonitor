# Listens on port 8090 — NAS calls SPARK ML/OpenFace over LAN
:8090 {
    # Max upload size for video files
    request_body {
        max_size 200MB
    }

    reverse_proxy bipolar_ml:8001 {
        header_up X-Real-IP {remote_host}
        # Generous timeout for ML inference + multipart video upload
        transport http {
            dial_timeout 10s
            response_header_timeout 600s
        }
    }

    header {
        X-Content-Type-Options "nosniff"
        -Server
    }

    log {
        output file /var/log/caddy/bipolar.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}
