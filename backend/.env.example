# Zkopíruj jako .env a vyplň hodnoty
# NIKDY necommituj .env do gitu
# Tyto proměnné platí pro SPARK (ML inference) — API běží na NASu

# PostgreSQL na NASu (přímý přístup přes LAN)
DATABASE_URL=postgresql+asyncpg://bipolar:PASSWORD@192.168.1.100:5432/bipolar

# MinIO na NASu (přímý přístup přes LAN)
MINIO_ENDPOINT=192.168.1.100:9000
MINIO_ACCESS_KEY=bipolar
MINIO_SECRET_KEY=change-me-strong-minio-password
MINIO_BUCKET=bipolar-media
MINIO_SECURE=false

# Callback na NAS API přes LAN (Caddy na portu 8088)
API_CALLBACK_URL=http://192.168.1.100:8088

# Webhook secret — musí souhlasit s ML_WEBHOOK_SECRET v nas/.env
ML_WEBHOOK_SECRET=change-me-random-secret
