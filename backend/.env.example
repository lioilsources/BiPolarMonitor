# JWT
JWT_SECRET=change-me-to-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (PostgreSQL on NAS)
DATABASE_URL=postgresql+asyncpg://bipolar:PASSWORD@192.168.1.100:5432/bipolar

# MinIO (on NAS)
MINIO_ENDPOINT=192.168.1.100:9000
MINIO_ACCESS_KEY=bipolar-access-key
MINIO_SECRET_KEY=bipolar-secret-key
MINIO_BUCKET=bipolar-media
MINIO_SECURE=false

# ML service
ML_SERVICE_URL=http://ml:8001

# Media retention (days)
MEDIA_RETENTION_DAYS=30
