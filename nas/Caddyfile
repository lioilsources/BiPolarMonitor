# Listens on port 8080 — exposed as 8088 on the host
# Cloudflare Tunnel connects here; SPARK ML callbacks arrive on LAN port 8088
:8080 {
    reverse_proxy bipolar_api:8000 {
        header_up X-Real-IP {remote_host}
        transport http {
            dial_timeout 5s
            response_header_timeout 120s
        }
    }

    header {
        X-Content-Type-Options "nosniff"
        -Server
    }

    log {
        output file /var/log/caddy/bipolar.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}
