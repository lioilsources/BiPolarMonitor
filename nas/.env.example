# Zkopíruj jako .env a vyplň hodnoty
# NIKDY necommituj .env do gitu

# ── PostgreSQL ─────────────────────────────────────────────────────────────
PG_PASSWORD=ZMEN_ME_silne_heslo

# ── MinIO ──────────────────────────────────────────────────────────────────
MINIO_USER=bipolar
MINIO_PASS=ZMEN_ME_silne_heslo

# ── API ────────────────────────────────────────────────────────────────────
JWT_SECRET=ZMEN_ME_min_32_znaku_nahodny_retezec
DATABASE_URL=postgresql+asyncpg://bipolar:ZMEN_ME_silne_heslo@bipolar_postgres:5432/bipolar
MINIO_ENDPOINT=bipolar-minio:9000
MINIO_ACCESS_KEY=bipolar
MINIO_SECRET_KEY=ZMEN_ME_silne_heslo
MINIO_BUCKET=bipolar-media
MINIO_SECURE=false

# FCM push notifikace (cesta k Firebase service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
ML_WEBHOOK_SECRET=ZMEN_ME_nahodny_retezec

# ML služba není na NAS — měření se uloží, analyzed=False dokud nenastavíš Spark
ML_SERVICE_URL=http://localhost:9999

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────
# Vytvoř tunnel na: https://one.dash.cloudflare.com → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=ZMEN_ME_token_z_cloudflare_dashboard
